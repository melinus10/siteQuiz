<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">

		<title>
			{% block title %}Welcome!
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
		{% block stylesheets %}
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
		{% endblock %}

		{% block javascripts %}{% endblock %}

		{% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
		{% if frankenphpHotReload %}
			<meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
			<script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
			<script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>

		{% endif %}
	</head>
	<body>
		{% block header %}
			<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
				<nav class="container mx-auto px-6 py-4 flex items-center justify-between">
					<h1 class="text-2xl font-black bg-gradient-to-r from-fuchsia-600 to-purple-600 bg-clip-text text-transparent">
						Genius Quizzes
					</h1>

					<ul class="hidden md:flex items-center gap-8 font-medium text-gray-600">
						<li>
							<a href="{{ path('home') }}" class="hover:text-fuchsia-600 transition">Home</a>
						</li>

						<li>
							<a href="{{ path('quiz', {'id': 1}) }}" class="hover:text-fuchsia-600 transition">Quiz</a>
						</li>

						{% if is_granted('IS_AUTHENTICATED_FULLY') %}
							<li>
								<a href="{{ path('admin_question_list') }}" class="hover:text-fuchsia-600 transition">Admin</a>
							</li>
							<li>
								<a href="{{ path('admin_user_list')}}" class="hover:text-fuchsia-600 transition">
									users
								</a>
							</li>
							<li>
								<a href="{{ path('logout') }}" class="bg-fuchsia-600 text-white px-6 py-2 rounded-full font-semibold hover:bg-fuchsia-700 transition shadow-lg shadow-fuchsia-200">
									Logout
								</a>
							</li>

						{% else %}
							<li>
								<a href="{{ path('login') }}" class="bg-fuchsia-600 text-white px-6 py-2 rounded-full font-semibold hover:bg-fuchsia-700 transition shadow-lg shadow-fuchsia-200">
									Log in
								</a>
							</li>
						{% endif %}
					</ul>
				</nav>
			</header>
		{% endblock %}

		{% block body %}{% endblock %}
	</body>
</html>
