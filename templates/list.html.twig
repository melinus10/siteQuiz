{% extends 'base.html.twig' %}

{% block body %}
<div class="max-w-4xl mx-auto my-10 p-8 bg-white rounded-3xl shadow-xl border border-gray-100">

    <h1 class="text-3xl font-black text-gray-800 mb-8 uppercase italic">
        Liste des questions
    </h1>

    <a href="{{ path('admin_question_new') }}"
       class="inline-block mb-8 px-6 py-3 bg-gradient-to-r from-fuchsia-600 to-purple-600 text-white font-bold rounded-xl shadow hover:scale-[1.02] transition">
        ➕ Ajouter une question
    </a>

    {% for question in questions %}
        <div class="mb-8 p-6 bg-gray-50 rounded-2xl border-2 border-gray-200 hover:border-fuchsia-300 transition-all">

            <h2 class="text-xl font-bold text-gray-800 mb-4">
                {{ question.question }}
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                {% for answer in question.answers %}
                    <div class="p-4 bg-white border border-gray-200 rounded-xl flex justify-between items-center">
                        <span class="text-gray-700">
                            {{ answer.text }}
                        </span>

                        {% if answer.isCorrect %}
                            <span class="text-green-500 font-bold">✔</span>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>

            <div class="flex items-center gap-4">

                
                <a href="{{ path('admin_question_edit', {'id': question.id}) }}"
                   class="px-5 py-2 bg-fuchsia-100 text-fuchsia-700 font-bold rounded-lg hover:bg-fuchsia-200 transition">
                    ✏️ Modifier
                </a>

                <form method="post"
                      action="{{ path('admin_question_delete', {'id': question.id}) }}"
                      onsubmit="return confirm('Tu es sûre de vouloir supprimer cette question ?');">

                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ question.id) }}">

                    <button type="submit"
                            class="px-5 py-2 bg-red-100 text-red-600 font-bold rounded-lg hover:bg-red-200 transition">
                        ❌ Supprimer
                    </button>
                </form>

            </div>
        </div>

    {% else %}
        <p class="text-gray-500 italic">Aucune question trouvée.</p>
    {% endfor %}

</div>
{% endblock %}