<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Genius Quizzes | Challenge Your Mind</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-50 text-gray-900 font-sans antialiased">

 <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
        <nav class="container mx-auto px-6 py-4 flex items-center justify-between">
            <h1 class="text-2xl font-black bg-gradient-to-r from-fuchsia-600 to-purple-600 bg-clip-text text-transparent">
                Genius Quizzes
            </h1>
            
            <ul class="hidden md:flex items-center gap-8 font-medium text-gray-600">
                <li><a href="{{ path('home') }}" class="hover:text-fuchsia-600 transition">Home</a></li>
                <li><a href="{{ path('quiz') }}" class="hover:text-fuchsia-600 transition">Quiz</a></li>
                <li><a href="#" class="hover:text-fuchsia-600 transition">About me</a></li>
                <li>
                    <a href="#" class="bg-fuchsia-600 text-white px-6 py-2 rounded-full font-semibold hover:bg-fuchsia-700 transition shadow-lg shadow-fuchsia-200">
                        Start Quiz
                    </a>
                </li>
            </ul>
        </nav>
    </header>
    
    <main>
        <section class="container mx-auto px-6 py-16 md:py-24 flex flex-col md:flex-row items-center gap-12">
            
            <div class="md:w-1/2 space-y-8">
                <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-gray-900 leading-tight">
                    Challenge Your Mind with <span class="text-fuchsia-600">Genius</span> Quizzes
                </h1>
                <p class="text-lg text-gray-600 leading-relaxed max-w-lg">
                    Discover the ultimate quiz experience with our carefully crafted questions designed to test your knowledge, sharpen your mind, and unlock your potential.
                </p>
                
                <div class="flex gap-4">
                    <button class="bg-fuchsia-600 text-white px-8 py-4 rounded-xl font-bold text-lg hover:scale-105 transition-transform shadow-xl shadow-fuchsia-100">
                        Get Started 
                    </button>
                    
                </div>
            </div>

            <div class="md:w-1/2 relative">
                <div class="absolute -top-4 -left-4 w-72 h-72 bg-purple-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob"></div>
                <div class="absolute -bottom-4 -right-4 w-72 h-72 bg-fuchsia-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob animation-delay-2000"></div>
                
                <img src="/images/main_quiz_img.jpg" 
                     alt="Quiz Image" 
                     class="relative rounded-3xl shadow-2xl w-full h-auto">
            </div>
            
        </section>
    </main>

    

</body>
</html>