{% extends 'base.html.twig' %}

{% block body %}
<body class="bg-gray-50 text-gray-900 font-sans antialiased">

    <main>
        <section class="container mx-auto px-6 py-16 md:py-24 flex flex-col md:flex-row items-center gap-12">
            
            <div class="md:w-1/2 space-y-8">
                <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-gray-900 leading-tight">
                    Challenge Your Mind with <span class="text-fuchsia-600">Genius</span> Quizzes
                </h1>
                <p class="text-lg text-gray-600 leading-relaxed max-w-lg">
                    Discover the ultimate quiz experience with our carefully crafted questions designed to test your knowledge, sharpen your mind, and unlock your potential.
                </p>
                
                
            </div>

            <div class="md:w-1/2 relative">
                <div class="absolute -top-4 -left-4 w-72 h-72 bg-purple-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob"></div>
                <div class="absolute -bottom-4 -right-4 w-72 h-72 bg-fuchsia-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob animation-delay-2000"></div>
                
                <img src="/images/main_quiz_img.jpg" 
                     alt="Quiz Image" 
                     class="relative rounded-3xl shadow-2xl w-full h-auto">
            </div>
            
        </section>
    </main>

{% endblock %}
    

