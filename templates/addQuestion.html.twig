{% extends 'base.html.twig' %}

{% block body %}
<div class="max-w-4xl mx-auto my-10 p-8 bg-white rounded-3xl shadow-xl border border-gray-100">
    <h1 class="text-3xl font-black text-gray-800 mb-8 uppercase italic">Ajouter une question</h1>

    {{ form_start(form) }}

        <div class="mb-10 p-6 bg-fuchsia-50 rounded-2xl border border-fuchsia-100">
            <label class="block font-bold text-fuchsia-700 mb-2">L'intitulé de la question</label>
            {{ form_widget(form.question, {
                'attr': {
                    'class': 'w-full p-4 border-2 border-gray-200 rounded-xl focus:border-fuchsia-500 focus:ring-fuchsia-500 outline-none bg-white transition-all',
                    'placeholder': 'Ex: Quelle est la capitale de la France ?'
                }
            }) }}
        </div>

        <h2 class="text-xl font-bold mb-4 text-gray-700 italic">Réponses possibles :</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {% for answerField in form.answers %}
                <div class="p-6 bg-gray-50 rounded-2xl border-2 border-gray-200 hover:border-fuchsia-300 transition-all focus-within:border-fuchsia-400 bg-white">
                    <p class="text-xs font-black text-fuchsia-400 mb-2 uppercase tracking-widest">Option {{ loop.index }}</p>
                    
                    {{ form_widget(answerField.text, {
                        'attr': {
                            'class': 'w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-fuchsia-500 focus:border-fuchsia-500 outline-none transition-all',
                            'placeholder': 'Entrez la réponse...'
                        }
                    }) }}

                    <div class="mt-4 flex items-center justify-between p-2 bg-gray-100 rounded-lg border border-gray-200">
                        <div class="flex items-center gap-2">
                            {{ form_widget(answerField.isCorrect, {
                                'attr': {'class': 'w-5 h-5 text-fuchsia-600 border-gray-300 rounded focus:ring-fuchsia-500'}
                            }) }}
                            <label class="text-sm font-bold text-gray-600">Bonne réponse ?</label>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <button type="submit" class="mt-10 w-full py-4 bg-gradient-to-r from-fuchsia-600 to-purple-600 text-white font-black rounded-2xl shadow-lg hover:scale-[1.01] transition-transform uppercase tracking-wider">
            ENREGISTRER LA QUESTION
        </button>
    {{ form_end(form) }}
</div>
{% endblock %}