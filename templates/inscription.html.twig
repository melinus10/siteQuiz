{% extends 'base.html.twig' %}

{% block body %}
<div class="max-w-4xl mx-auto my-10 p-8 bg-white rounded-3xl shadow-xl border border-gray-100">
    
    <h1 class="text-3xl font-black text-gray-800 mb-8 uppercase italic">
        Modifier le user
    </h1>
    
    {{ form_start(form) }}

    {# Bloc Username #}
    <div class="mb-6 p-6 bg-fuchsia-50 rounded-2xl border border-fuchsia-100">
        <label class="block font-bold text-fuchsia-700 mb-2">
            Nom d'utilisateur
        </label>
        {{ form_widget(form.username, {
            'attr': {
                'class': 'w-full p-4 border-2 border-gray-200 rounded-xl focus:border-fuchsia-500 focus:ring-fuchsia-500 outline-none bg-white transition-all'
            }
        }) }}
    </div>

    <div class="mb-6 p-6 bg-fuchsia-50 rounded-2xl border border-fuchsia-100">
        <label class="block font-bold text-fuchsia-700 mb-2">
            Nouveau mot de passe
        </label>
        {{ form_widget(form.password, {
            'attr': {
                'class': 'w-full p-4 border-2 border-gray-200 rounded-xl focus:border-fuchsia-500 focus:ring-fuchsia-500 outline-none bg-white transition-all'
            },
            'value': ''  
        }) }}
    </div>
    <div> 
            <label class="block font-bold text-fuchsia-700 mb-2">
                Photo de profil
            </label>
            {{ form_widget(form.photoprofile, {
                'attr': {
                    'class': 'w-full p-4 border-2 border-gray-200 rounded-xl focus:border-fuchsia-500 focus:ring-fuchsia-500 outline-none bg-white transition-all'
                }
            }) }}
    </div>
    <button type="submit"
            class="mt-10 w-full py-4 bg-gradient-to-r from-fuchsia-600 to-purple-600 text-white font-black rounded-2xl shadow-lg hover:scale-[1.01] transition-transform uppercase tracking-wider">
        Inscritpion
    </button>

    {{ form_end(form) }}
</div>
{% endblock %}