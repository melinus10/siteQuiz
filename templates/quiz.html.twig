{% extends 'base.html.twig' %}

{% block body %}
<main class="container mx-auto px-6 py-12">
    <div class="max-w-2xl mx-auto bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
        <h1 class="text-3xl font-bold text-gray-800 mb-6">Quiz : Testez vos connaissances</h1>
        <p class="text-gray-600 mb-8">Répondez aux questions ci-dessous pour valider votre score.</p>
        
        <div class="space-y-6 custom-form bg-gray-50 p-6 rounded-xl border border-gray-200">
            {{ form_start(form) }}
                {{ form_row(form) }}
                <div class="mt-8">
                    <button type="submit" class="w-full bg-gradient-to-r from-fuchsia-600 to-purple-600 text-white font-bold py-3 px-6 rounded-xl hover:opacity-90 transition shadow-lg">
                        Valider 
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</main>

<style>
    .custom-form label { @apply block text-sm font-semibold text-gray-700 mb-1 mt-4; }
    .custom-form input { @apply w-full p-5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-fuchsia-500 focus:border-transparent outline-none transition; }
</style>
{% endblock %}
