<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz</title>
</head>
<body>
    <h1>Quiz</h1>
    <p>Bienvenue dans le quiz!</p>
   {% for question in questions %}
    <p>{{ question.question }}</p>
    <ul>
    {% for answer in question.answers %}
        <li>{{ answer.text }}</li>
    {% endfor %}
    </ul>
{% endfor %}
</body>
</html>

