{% extends 'base.html.twig' %}

{% block body %}
<div class="max-w-2xl mx-auto my-20 p-8 bg-white rounded-3xl shadow-xl border border-gray-100">

    <h1 class="text-3xl font-black text-gray-800 mb-8 uppercase italic text-center">
        Log in 
    </h1>

    {% if error %}
        <div class="mb-6 p-4 bg-red-100 border border-red-200 rounded-xl text-red-700 font-semibold">
            {{ error.messageKey }}
        </div>
    {% endif %}

    <form action="{{ path('login') }}" method="post" class="space-y-6">

        <div class="mb-6 p-6 bg-fuchsia-50 rounded-2xl border border-fuchsia-100">
            <label for="username" class="block font-bold text-fuchsia-700 mb-2">
                Nom d'utilisateur
            </label>
            <input type="text" name="_username" id="username" value="{{ last_username }}"
                   class="w-full p-4 border-2 border-gray-200 rounded-xl focus:border-fuchsia-500 focus:ring-fuchsia-500 outline-none bg-white transition-all"
                   required autofocus>
        </div>

        <div class="mb-6 p-6 bg-fuchsia-50 rounded-2xl border border-fuchsia-100">
            <label for="password" class="block font-bold text-fuchsia-700 mb-2">
                Mot de passe
            </label>
            <input type="password" name="_password" id="password"
                   class="w-full p-4 border-2 border-gray-200 rounded-xl focus:border-fuchsia-500 focus:ring-fuchsia-500 outline-none bg-white transition-all"
                   required>
        </div>

        <button type="submit"
                class="w-full py-4 bg-gradient-to-r from-fuchsia-600 to-purple-600 text-white font-black rounded-2xl shadow-lg hover:scale-[1.01] transition-transform uppercase tracking-wider">
            Connexion
        </button>
      <p class="mt-6 text-center text-gray-500">
        Pas de compte ? 
        <a href="{{ path('inscription') }}" class="text-fuchsia-600 font-bold hover:underline">
            Créer un profil
        </a>
    </p>

    </form>
</div>
{% endblock %}