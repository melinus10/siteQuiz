{% extends 'base.html.twig' %}

{% block title %}Résultats - Genius Quizzes{% endblock %}

{% block body %}
<main class="min-h-screen bg-gray-50 py-12 px-6">
    <div class="max-w-3xl mx-auto">
        
        <div class="bg-white rounded-3xl p-8 shadow-xl shadow-fuchsia-100 border border-fuchsia-50 text-center mb-10">
            <h1 class="text-4xl font-black text-gray-800 mb-2">Quiz Terminé !</h1>
            <p class="text-gray-500 uppercase tracking-widest font-bold text-sm">Ton Score Final</p>
            <div class="mt-4 inline-block px-8 py-4 bg-gradient-to-r from-fuchsia-600 to-purple-600 rounded-2xl shadow-lg shadow-fuchsia-200">
                <span class="text-5xl font-black text-white">{{ score }}</span>
                <span class="text-2xl text-fuchsia-100"> / {{ maxScore }}</span>
            </div>
        </div>

        <div class="space-y-6">
            {% for item in results %}
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 transition hover:shadow-md">
                    <div class="p-6">
                        {# Question #}
                        <div class="flex items-start gap-4 mb-4">
                            <span class="flex-shrink-0 w-8 h-8 bg-fuchsia-100 text-fuchsia-600 rounded-full flex items-center justify-center font-bold text-sm">
                                {{ loop.index }}
                            </span>
                            <h3 class="text-lg font-bold text-gray-800 pt-1 leading-tight">
                                {{ item.question.question }}
                            </h3>
                        </div>

                        {# Zone Réponse #}
                        <div class="m-12 p-4 rounded-xl {% if item.isCorrect %}bg-emerald-50 border border-emerald-100{% else %}bg-rose-50 border border-rose-100{% endif %}">
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="text-sm {% if item.isCorrect %}text-emerald-600{% else %}text-rose-600{% endif %} font-semibold uppercase tracking-wider">
                                        Ta réponse
                                    </p>
                                    <p class="text-gray-800 font-medium">{{ item.text }}</p>
                                </div>
                                <span class="text-2xl">
                                    {{ item.isCorrect ? '✅' : '❌' }}
                                </span>
                            </div>

                            {# Correction si faux #}
                            {% if not item.isCorrect %}
                                <div class="mt-4 pt-4 border-t border-rose-200">
                                    <p class="text-sm text-gray-500 italic">La bonne réponse était :</p>
                                    {% for choice in item.question.answers %}
                                        {% if choice.isCorrect %}
                                            <p class="text-emerald-600 font-bold text-lg">{{ choice.text }}</p>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="mt-12 text-center">
            <a href="{{ path('home') }}" class="inline-flex items-center gap-2 px-8 py-3 bg-white border-2 border-gray-200 text-gray-600 font-bold rounded-2xl hover:bg-gray-50 hover:border-fuchsia-600 hover:text-fuchsia-600 transition-all shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Retour à l'accueil
            </a>
        </div>

    </div>
</main>
{% endblock %}